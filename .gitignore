# FinNews - Git Ignore File

# Environment variables
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store

# Git worktrees
.worktrees/

# Outputs
outputs/raw/*.json
outputs/processed/*.md
outputs/logs/*.log
outputs/storage/*.json
outputs/*.json

!outputs/comex_history.json
outputs/digest_preview_*.html

# Keep directory structure
!outputs/raw/.gitkeep
!outputs/processed/.gitkeep
!outputs/logs/.gitkeep

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Database (if enabled)
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.bak
*.cache
