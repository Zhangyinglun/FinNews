# ================================================================================
# FinNews API Configuration
# 复制此文件为 .env 并填入您的API密钥
# ================================================================================

# ========================================
# 核心API密钥 (必需)
# ========================================

# Tavily API - 新闻搜索与地缘政治信息
# 获取地址: https://app.tavily.com/
# 免费额度: 1000 credits/月
TAVILY_API_KEY=tvly-your-32-character-api-key-here

# FRED API - 美联储经济数据
# 获取地址: https://fredaccount.stlouisfed.org/apikeys
# 免费额度: 100,000 requests/天
FRED_API_KEY=your-fred-32-character-api-key-here


# ========================================
# 备选API密钥 (可选)
# ========================================

# Alpha Vantage API - 备用数据源
# 获取地址: https://www.alphavantage.co/support/#api-key
# 免费额度: 25 requests/天 (限制较多，不推荐作为主力)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# ========================================
# 运行配置
# ========================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# 数据源开关 (可选配置)
# ========================================

# 启用/禁用各数据源 (true/false)
ENABLE_TAVILY=true
ENABLE_DDG=true
ENABLE_YFINANCE=true
ENABLE_RSS=true
ENABLE_FRED=true
ENABLE_ALPHA_VANTAGE=false

# ========================================
# 多时间窗口配置
# ========================================

# Flash Window - 即时窗口(小时)
FLASH_WINDOW_HOURS=24

# Cycle Window - 周度窗口(天)
CYCLE_WINDOW_DAYS=7

# Trend Window - 月度窗口(天)
TREND_WINDOW_DAYS=30

# ========================================
# DuckDuckGo (ddgs) 配置
# ========================================

# 搜索区域 (示例: us-en, uk-en, wt-wt)
DDG_REGION=us-en

# 后端选择 (auto 或指定后端，如 duckduckgo, bing, yahoo)
DDG_BACKEND=auto

# 单次查询最大返回数量
DDG_MAX_RESULTS=5

# ========================================
# 规则引擎阈值配置
# ========================================

# VIX绝对值警戒线 (超过此值标记为警戒)
VIX_ALERT_THRESHOLD=20

# VIX暴涨百分比阈值 (日变化超过此值触发紧急警报)
VIX_SPIKE_PERCENT=5

# DXY显著变化阈值(%)
DXY_CHANGE_THRESHOLD=0.5

# 10Y国债收益率变化阈值(%)
US10Y_CHANGE_THRESHOLD=2

# ========================================
# 高级配置 (可选)
# ========================================

# 最大重试次数
MAX_RETRIES=3

# 请求超时时间(秒)
REQUEST_TIMEOUT=30

# 去重时间窗口(小时)
DEDUPLICATION_WINDOW_HOURS=24

# ========================================
# 邮件摘要配置 (OpenRouter -> Gmail SMTP)
# ========================================

# 摘要滚动窗口(小时)
DIGEST_WINDOW_HOURS=24

# 摘要是否允许向LLM提供 full_content (通常不需要)
DIGEST_INCLUDE_FULL_CONTENT=false

# 若开启 full_content，单条文章最大字符数
DIGEST_FULL_CONTENT_MAX_CHARS_PER_ARTICLE=2000

# Sonar (via OpenRouter)
ENABLE_SONAR=false
SONAR_MODEL=perplexity/sonar
SONAR_USE_TRUSTED_DOMAINS=false

# OpenRouter (LLM API)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3-pro-preview
OPENROUTER_TEMPERATURE=0.3
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TIMEOUT=120
OPENROUTER_MAX_RETRIES=3

# 可选：OpenRouter推荐header
# OPENROUTER_HTTP_REFERER=https://your-domain.example
# OPENROUTER_X_TITLE=FinNews

# Gmail SMTP (建议使用Google App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_google_app_password

# 邮件头
EMAIL_FROM=FinNews <your_gmail_address@gmail.com>
EMAIL_TO=recipient1@example.com,recipient2@example.com
